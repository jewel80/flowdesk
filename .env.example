# FlowDesk environment overrides.
# Copy to `.env` to customise. The stack runs with built-in defaults without it.

# --- Postgres ---
POSTGRES_USER=flowdesk
POSTGRES_PASSWORD=flowdesk
POSTGRES_DB=flowdesk
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- API ---
API_PORT=3000
# Optional: comma-separated read-replica URLs. Empty → reads use the primary.
# Use the docker-compose.replica.yml override to spin up a real streaming replica.
DATABASE_REPLICA_URLS=
JWT_SECRET=super-secret-dev-key-change-me
JWT_EXPIRES_IN=1d
CORS_ORIGIN=*
INVOICE_DUE_IN_DAYS=30

# --- Web ---
WEB_PORT=8080
