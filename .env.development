# Development environment values for Docker Compose (`npm run dev`).
# Consumed via `docker compose --env-file .env.development`.
# Safe local defaults only — no real secrets.
NODE_ENV=development

# Host port mappings
API_PORT=3000
WEB_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

# Postgres
POSTGRES_USER=flowdesk
POSTGRES_PASSWORD=flowdesk
POSTGRES_DB=flowdesk

# API
JWT_SECRET=dev-secret-not-for-production
JWT_EXPIRES_IN=1d
CORS_ORIGIN=*
INVOICE_DUE_IN_DAYS=30
