# Production values for Docker Compose. Copy to `.env.production` (git-ignored)
# and inject real values from your secret manager. Used by: npm run prod
#
# Generate a strong secret:  openssl rand -base64 48
NODE_ENV=production

API_PORT=3000
WEB_PORT=80
POSTGRES_PORT=5432
REDIS_PORT=6379

POSTGRES_USER=flowdesk
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=flowdesk

JWT_SECRET=replace-with-a-strong-randomly-generated-secret
JWT_EXPIRES_IN=1h
CORS_ORIGIN=https://flowdesk.example.com
INVOICE_DUE_IN_DAYS=30
