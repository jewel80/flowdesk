# Staging environment template. Copy to `.env.staging` and fill in real values.
# `.env.staging` is git-ignored.
NODE_ENV=staging
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@staging-db-host:5432/flowdesk?schema=public
# Comma-separated read replicas, e.g. postgresql://USER:PASSWORD@staging-replica:5432/flowdesk?schema=public
DATABASE_REPLICA_URLS=
JWT_SECRET=replace-with-a-strong-staging-secret
JWT_EXPIRES_IN=12h
REDIS_HOST=staging-redis-host
REDIS_PORT=6379
CORS_ORIGIN=https://staging.flowdesk.example.com
INVOICE_DUE_IN_DAYS=30
