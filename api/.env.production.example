# Production environment template. Copy to `.env.production` and fill in real
# values from your secret manager. `.env.production` is git-ignored.
#
# Generate a strong JWT secret, e.g.:  openssl rand -base64 48
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@prod-db-host:5432/flowdesk?schema=public
# Strongly recommended in production: route reads to one or more replicas.
DATABASE_REPLICA_URLS=postgresql://USER:PASSWORD@prod-replica-1:5432/flowdesk?schema=public
JWT_SECRET=replace-with-a-strong-randomly-generated-secret
JWT_EXPIRES_IN=1h
REDIS_HOST=prod-redis-host
REDIS_PORT=6379
CORS_ORIGIN=https://flowdesk.example.com
INVOICE_DUE_IN_DAYS=30
