# Local (non-Docker) API development. Copy to `.env`.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://flowdesk:flowdesk@localhost:5432/flowdesk?schema=public
# Optional: comma-separated read-replica URLs. Empty → reads use the primary.
# DATABASE_REPLICA_URLS=postgresql://flowdesk:flowdesk@localhost:5433/flowdesk?schema=public
JWT_SECRET=super-secret-dev-key-change-me
JWT_EXPIRES_IN=1d
REDIS_HOST=localhost
REDIS_PORT=6379
CORS_ORIGIN=http://localhost:5173
INVOICE_DUE_IN_DAYS=30
