# Staging values for Docker Compose. Copy to `.env.staging` (git-ignored) and
# fill in real values. Used by: npm run staging
NODE_ENV=staging

API_PORT=3000
WEB_PORT=8080
# In staging/prod the DB/Redis are usually NOT published to the host (see
# docker-compose.prod.yml). These remain for completeness.
POSTGRES_PORT=5432
REDIS_PORT=6379

POSTGRES_USER=flowdesk
POSTGRES_PASSWORD=change-me-staging
POSTGRES_DB=flowdesk

JWT_SECRET=replace-with-a-strong-staging-secret
JWT_EXPIRES_IN=12h
CORS_ORIGIN=https://staging.flowdesk.example.com
INVOICE_DUE_IN_DAYS=30
