# Dependencies
node_modules/

# Build output
dist/
build/
coverage/
*.tsbuildinfo

# Environment
# Ignore the generic .env and any *.local files.
.env
.env.local
*.local
# Ignore real staging/production secret files; keep .env.development and
# *.example tracked. (Frontend web/.env.* are public config and stay tracked.)
/.env.staging
/.env.production
/api/.env.staging
/api/.env.production

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Prisma local engine cache
api/prisma/*.db

# Playwright (frontend E2E) artifacts
web/playwright-report/
web/test-results/
web/playwright/.cache/
